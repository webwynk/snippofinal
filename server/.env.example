NODE_ENV=development
PORT=4000

# Use: npm run jwt:secret
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Comma-separated origins
CORS_ORIGINS=http://localhost:5173

# true when behind reverse proxy (Hostinger, Nginx, Cloudflare, etc.)
TRUST_PROXY=false

# Global throttling
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000

# Extra protection for login/register endpoints
AUTH_RATE_LIMIT_MAX=500

# Optional absolute/relative path override for db.json
DATA_FILE=./data/db.json

# demo: seeded demo users; secure: admin-only bootstrap (recommended for production)
SEED_MODE=demo
ADMIN_BOOTSTRAP_NAME=Admin
ADMIN_BOOTSTRAP_EMAIL=owner@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-password

# SMTP Configuration
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME="Snippo Booking"
SMTP_FROM_EMAIL=

# Resend API Configuration
RESEND_API_KEY=
